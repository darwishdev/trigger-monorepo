<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ======================================================= -->
        <!-- Developers (res.partner)                                 -->
        <!-- ======================================================= -->
        <record id="dev_emaar" model="res.partner">
            <field name="name">Emaar Misr</field>
            <field name="company_type">company</field>
            <field name="city">Cairo</field>
            <field name="country_id" ref="base.eg"/>
        </record>
        <record id="dev_ora" model="res.partner">
            <field name="name">Ora Developers</field>
            <field name="company_type">company</field>
            <field name="city">Giza</field>
            <field name="country_id" ref="base.eg"/>
        </record>
        <record id="dev_palmhills" model="res.partner">
            <field name="name">Palm Hills Developments</field>
            <field name="company_type">company</field>
            <field name="city">Giza</field>
            <field name="country_id" ref="base.eg"/>
        </record>

        <!-- ======================================================= -->
        <!-- Projects (product.category, is_project=True)             -->
        <!-- ======================================================= -->
        <record id="project_mivida" model="product.category">
            <field name="name">Mivida</field>
            <field name="is_project" eval="True"/>
            <field name="location">New Cairo</field>
            <field name="developer_id" ref="dev_emaar"/>
            <field name="delivery_date" eval="(DateTime.now() + relativedelta(months=10)).strftime('%Y-%m-%d')"/>
        </record>

        <record id="project_marassi" model="product.category">
            <field name="name">Marassi</field>
            <field name="is_project" eval="True"/>
            <field name="location">North Coast (Sahel)</field>
            <field name="developer_id" ref="dev_emaar"/>
            <field name="delivery_date" eval="(DateTime.now() + relativedelta(months=18)).strftime('%Y-%m-%d')"/>
        </record>

        <record id="project_zed" model="product.category">
            <field name="name">ZED Towers</field>
            <field name="is_project" eval="True"/>
            <field name="location">Sheikh Zayed</field>
            <field name="developer_id" ref="dev_ora"/>
            <field name="delivery_date" eval="(DateTime.now() + relativedelta(months=24)).strftime('%Y-%m-%d')"/>
        </record>

        <record id="project_hacienda" model="product.category">
            <field name="name">Hacienda Bay</field>
            <field name="is_project" eval="True"/>
            <field name="location">North Coast (Sahel)</field>
            <field name="developer_id" ref="dev_palmhills"/>
            <field name="delivery_date" eval="(DateTime.now() + relativedelta(months=6)).strftime('%Y-%m-%d')"/>
        </record>

    </data>
</odoo>
